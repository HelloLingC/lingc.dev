---
import "../styles/main.css";
import { Image } from "astro:assets";
import GithubHeatmap from "../components/GithubHeatmap.astro";
import { projects } from "../data/projects";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>LingC's Homepage</title>
    <style></style>
  </head>
  <body>
    <div class="site">
      <header class="site-header">
        <div class="profile">
          <img
            class="profile-avatar"
            src="/avatar.jpg"
            alt="LingC's avatar"
            width="128"
            height="128"
            loading="eager"
            decoding="async"
          />

          <div class="profile-content">
            <h1 class="profile-name">LingC</h1>
            <p class="profile-description">
              A software developer and a computer lover.
            </p>

            <div class="social-links" aria-label="Social media">
              <a
                href="https://github.com/hellolingc"
                aria-label="GitHub profile"
                class="github-link"
              >
                <svg
                  role="img"
                  viewBox="0 0 24 24"
                  width="22"
                  height="22"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <title>GitHub</title>
                  <path
                    d="M12 .7a11.5 11.5 0 0 0-3.64 22.41c.58.11.79-.25.79-.56v-2.24c-3.22.7-3.9-1.37-3.9-1.37-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.57-.29-5.27-1.28-5.27-5.68 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.16 1.18A10.9 10.9 0 0 1 12 6.13c.98 0 1.95.13 2.87.39 2.2-1.49 3.16-1.18 3.16-1.18.63 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.08 0 4.41-2.7 5.38-5.28 5.67.42.36.78 1.06.78 2.14v3.28c0 .31.21.68.8.56A11.5 11.5 0 0 0 12 .7Z"
                  ></path>
                </svg>
                GitHub
              </a>

              <a
                href="https://x.com/mutta02"
                aria-label="X profile"
                class="x-link"
              >
                <svg
                  role="img"
                  viewBox="0 0 24 24"
                  width="22"
                  height="22"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <title>X</title>
                  <path
                    d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.292 19.492h2.039L6.486 3.24H4.298l13.311 17.405z"
                  ></path>
                </svg>
                X
              </a>

              <a
                href="https://www.youtube.com/@mutta02"
                aria-label="YouTube channel"
                class="youtube-link"
              >
                <svg
                  role="img"
                  viewBox="0 0 24 24"
                  width="22"
                  height="22"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <title>YouTube</title>
                  <path
                    d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                  ></path>
                </svg>
                YouTube
              </a>

              <a
                href="https://space.bilibili.com/15384672"
                aria-label="Bilibili profile"
                class="bilibili-link"
              >
                <svg
                  role="img"
                  viewBox="0 0 24 24"
                  width="22"
                  height="22"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <title>Bilibili</title>
                  <path
                    d="M18.223 3.086a1.25 1.25 0 0 1 0 1.768L17.08 5.996h1.17A3.75 3.75 0 0 1 22 9.747v7.5a3.75 3.75 0 0 1-3.75 3.75H5.75A3.75 3.75 0 0 1 2 17.247v-7.5a3.75 3.75 0 0 1 3.75-3.75h1.166L5.775 4.855a1.25 1.25 0 1 1 1.767-1.768l2.652 2.652c.079.079.145.165.198.257h3.213c.053-.092.12-.18.199-.258l2.651-2.652a1.25 1.25 0 0 1 1.768 0zm.027 5.42H5.75a1.25 1.25 0 0 0-1.247 1.157l-.003.094v7.5c0 .659.51 1.199 1.157 1.246l.093.004h12.5a1.25 1.25 0 0 0 1.247-1.157l.003-.093v-7.5c0-.69-.56-1.25-1.25-1.25zm-10 2.5c.69 0 1.25.56 1.25 1.25v1.25a1.25 1.25 0 1 1-2.5 0v-1.25c0-.69.56-1.25 1.25-1.25zm7.5 0c.69 0 1.25.56 1.25 1.25v1.25a1.25 1.25 0 1 1-2.5 0v-1.25c0-.69.56-1.25 1.25-1.25z"
                  ></path>
                </svg>
                Bilibili
              </a>
            </div>
          </div>
        </div>
      </header>

      <main>
        <section>
          <div class="section-heading">
            <h2>Articles</h2>
            <a class="view-all-link" href="https://lycois.org/">
              View all articles
            </a>
          </div>

          <ul class="post-list">
            <li class="post-item">
              <a class="post-link" href="#">
                <div>
                  <h3 class="post-title">
                    Why I Started Learning Operating Systems
                  </h3>
                  <p class="post-summary">
                    Questions I encountered while moving from application
                    development toward the foundations of computing.
                  </p>
                </div>

                <time class="post-date">2026.07.15</time>
              </a>
            </li>
          </ul>
        </section>

        <section class="projects-section" aria-labelledby="projects-title">
          <div class="section-heading">
            <h2 id="projects-title">Projects</h2>
            <p>Ongoing work</p>
          </div>

          <div class="projects-grid">
            {
              projects.map((project) => (
                <a class="project-card" href={project.href}>
                  <div class="project-media">
                    {
                      typeof project.image === "string" ? (
                        <img
                          src={project.image}
                          alt={project.imageAlt}
                          width="800"
                          height="500"
                          loading="lazy"
                        />
                      ) : (
                        <Image
                          src={project.image}
                          alt={project.imageAlt}
                          widths={[320, 640, 960, 1600]}
                          sizes="(max-width: 560px) 90vw, (max-width: 760px) 45vw, 231px"
                          format="webp"
                          loading="lazy"
                        />
                      )
                    }
                  </div>
                  <div class="project-content">
                    <time
                      class="project-started-at"
                      datetime={project.startedAt}
                    >
                      {project.startedAt}
                    </time>
                    <h3>{project.name}</h3>
                    <p>{project.description}</p>
                  </div>
                </a>
              ))
            }
          </div>
        </section>

        <GithubHeatmap />
      </main>
      <footer class="site-footer">© 2026 Ling · Built quietly.</footer>
    </div>
  </body>
</html>
