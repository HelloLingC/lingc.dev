---
const username = "hellolingc";
---

<section class="github-card" aria-labelledby="github-title">
  <h2 id="github-title">GitHub Contributions</h2>

  <p id="github-total" class="github-total">Loading contributions…</p>

  <div
    id="github-heatmap"
    class="github-heatmap"
    aria-label={`GitHub contribution heatmap for ${username}`}
  >
  </div>
</section>

<script>
  type ContributionDay = {
    date: string;
    contributionCount: number;
    color: string;
  };

  type ContributionWeek = {
    contributionDays: ContributionDay[];
  };

  type ContributionCalendar = {
    totalContributions: number;
    weeks: ContributionWeek[];
  };

  async function loadGithubHeatmap() {
    const heatmap = document.querySelector("#github-heatmap");
    const total = document.querySelector("#github-total");

    if (!heatmap || !total) return;

    const response = await fetch("/api/github-contributions");
    const calendar: ContributionCalendar = await response.json();

    total.textContent = `${calendar.totalContributions} contributions in the last year`;

    for (const week of calendar.weeks) {
      const weekEl = document.createElement("div");
      weekEl.className = "github-week";

      for (const day of week.contributionDays) {
        const dayEl = document.createElement("span");
        dayEl.className = "github-day";
        dayEl.style.backgroundColor = day.color;
        dayEl.title = `${day.date}: ${day.contributionCount} contributions`;
        dayEl.setAttribute(
          "aria-label",
          `${day.date}: ${day.contributionCount} contributions`,
        );

        weekEl.appendChild(dayEl);
      }

      heatmap.appendChild(weekEl);
    }
  }

  loadGithubHeatmap();
</script>

<style>
  .github-card {
    max-width: 760px;
  }

  .github-total {
    margin-bottom: 0.75rem;
    opacity: 0.75;
  }

  .github-heatmap {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    padding-block: 0.5rem;
  }

  .github-week {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .github-day {
    width: 11px;
    height: 11px;
    border-radius: 2px;
    flex: 0 0 auto;
  }
</style>
